<%- include("partials/header", { title: "Main page" }) %>

  <div class="home-hero">
    <div class="home-hero-inner">
      <p class="home-kicker">Welcome back, <strong>
          <%= user.username %>
        </strong></p>
      <h1 class="home-title">
        <%= siteName %>
      </h1>
      <p class="home-desc">Your private knowledge base — organised, searchable, always up to date.</p>
      <div class="home-hero-actions">
        <a href="/search" class="home-btn home-btn-primary">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
            stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          Browse all articles
        </a>
        <% if (canEdit || user.role==="admin" ) { %>
          <a href="/wiki/new" class="home-btn home-btn-secondary">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
              stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            New article
          </a>
          <% } %>
      </div>
    </div>
    <div class="home-hero-stats">
      <div class="home-hero-stat">
        <span class="home-hero-stat-num">
          <%= totalPages %>
        </span>
        <span class="home-hero-stat-label">Articles</span>
      </div>
      <div class="home-hero-stat">
        <span class="home-hero-stat-num">
          <%= totalCategories %>
        </span>
        <span class="home-hero-stat-label">Categories</span>
      </div>
    </div>
  </div>

  <div class="home-body">

    <div class="home-main">
      <div class="home-section-header">
        <h2 class="home-section-title">Recently updated</h2>
        <a href="/search" class="home-section-link">View all articles →</a>
      </div>

      <% if (recent.length===0) { %>
        <div class="home-empty">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
          </svg>
          <p>No articles yet. <a href="/wiki/new">Create the first one.</a></p>
        </div>
        <% } else { %>
          <div class="home-grid">
            <% recent.forEach((item)=> {
              const updated = new Date(item.updated_at);
              const now = new Date();
              const diffMs = now - updated;
              const diffMins = Math.floor(diffMs / 60000);
              const diffHours = Math.floor(diffMs / 3600000);
              const diffDays = Math.floor(diffMs / 86400000);
              let timeLabel;
              if (diffMins < 60) { timeLabel=diffMins <=1 ? 'Just now' : diffMins + 'm ago' ; } else if (diffHours < 24)
                { timeLabel=diffHours + 'h ago' ; } else if (diffDays < 7) { timeLabel=diffDays + 'd ago' ; } else {
                timeLabel=updated.toLocaleDateString(undefined, { month: 'short' , day: 'numeric' , year:
                updated.getFullYear() !==now.getFullYear() ? 'numeric' : undefined }); } const palettes=[
                {bg:'#1e3a5f',fg:'#93c5fd'},{bg:'#4a1942',fg:'#f9a8d4'},
                {bg:'#14532d',fg:'#86efac'},{bg:'#451a03',fg:'#fcd34d'},
                {bg:'#2e1065',fg:'#c4b5fd'},{bg:'#042f2e',fg:'#5eead4'},
                {bg:'#450a0a',fg:'#fca5a5'},{bg:'#052e16',fg:'#6ee7b7'}, ]; const idx=item.title.charCodeAt(0) %
                palettes.length; %>
                <a href="/wiki/<%= item.slug %>" class="home-card">
                  <div class="home-card-avatar"
                    style="background:<%- palettes[idx].bg %>;color:<%- palettes[idx].fg %>">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                      stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                      <polyline points="14 2 14 8 20 8" />
                      <line x1="16" y1="13" x2="8" y2="13" />
                      <line x1="16" y1="17" x2="8" y2="17" />
                      <polyline points="10 9 9 9 8 9" />
                    </svg>
                  </div>
                  <div class="home-card-content">
                    <div class="home-card-title">
                      <%= item.title %>
                    </div>
                    <div class="home-card-time">
                      <%= timeLabel %>
                    </div>
                  </div>
                  <svg class="home-card-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6" />
                  </svg>
                </a>
                <% }) %>
          </div>
          <% } %>
    </div>

    <aside class="home-side">
      <div class="home-widget">
        <h3 class="home-widget-title">Quick actions</h3>
        <nav class="home-quick-nav">
          <a href="/search" class="home-quick-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            Search articles
          </a>
          <% if (canEdit || user.role==="admin" ) { %>
            <a href="/wiki/new" class="home-quick-link">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
              </svg>
              Write new article
            </a>
            <% } %>
              <a href="/wiki/random" class="home-quick-link">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="16 3 21 3 21 8" />
                  <line x1="4" y1="20" x2="21" y2="3" />
                  <polyline points="21 16 21 21 16 21" />
                  <line x1="15" y1="15" x2="21" y2="21" />
                </svg>
                Random article
              </a>
              <% if (user.role==="admin" ) { %>
                <a href="/admin/users" class="home-quick-link">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  </svg>
                  Manage users
                </a>
                <% } %>
        </nav>
      </div>

      <div class="home-widget">
        <h3 class="home-widget-title">Tips &amp; syntax</h3>
        <ul class="home-tips-list">
          <li>Link pages with <kbd>[[PageTitle]]</kbd></li>
          <li>Categorise with <kbd>[[Category:Name]]</kbd></li>
          <li>Structure content with <kbd>## Heading</kbd></li>
        </ul>
      </div>

      <div class="home-widget dyk-widget" id="dyk-widget">
        <div class="dyk-header">
          <h3 class="home-widget-title" style="margin:0">Did you know</h3>
          <button class="dyk-refresh" id="dyk-refresh" title="Get another fact" aria-label="Refresh fact">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 4 23 10 17 10" />
              <polyline points="1 20 1 14 7 14" />
              <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" />
            </svg>
          </button>
        </div>
        <div class="dyk-body" id="dyk-body">
          <div class="dyk-loading" id="dyk-loading">
            <span class="dyk-spinner"></span>
            Generating fact...
          </div>
          <div class="dyk-content hidden" id="dyk-content">
            <p class="dyk-fact" id="dyk-fact"></p>
            <a class="dyk-source" id="dyk-source" href="#"></a>
          </div>
          <div class="dyk-error hidden" id="dyk-error">Could not load a fact right now.</div>
        </div>
      </div>
    </aside>

    <script>
      (function () {
        function loadDyk(force) {
          var loading = document.getElementById('dyk-loading');
          var content = document.getElementById('dyk-content');
          var error = document.getElementById('dyk-error');
          var factEl = document.getElementById('dyk-fact');
          var srcEl = document.getElementById('dyk-source');
          var btn = document.getElementById('dyk-refresh');

          loading.classList.remove('hidden');
          content.classList.add('hidden');
          error.classList.add('hidden');
          if (btn) btn.classList.add('dyk-spin');

          fetch('/api/did-you-know' + (force ? '?refresh=1' : ''))
            .then(function (r) { return r.json(); })
            .then(function (data) {
              if (btn) btn.classList.remove('dyk-spin');
              loading.classList.add('hidden');
              if (data.ok) {
                factEl.textContent = data.fact;
                srcEl.textContent = '— ' + data.title;
                srcEl.href = '/wiki/' + data.slug;
                content.classList.remove('hidden');
              } else {
                error.classList.remove('hidden');
              }
            })
            .catch(function () {
              if (btn) btn.classList.remove('dyk-spin');
              loading.classList.add('hidden');
              error.classList.remove('hidden');
            });
        }

        loadDyk(false);

        var btn = document.getElementById('dyk-refresh');
        if (btn) btn.addEventListener('click', function () { loadDyk(true); });
      })();
    </script>

  </div>

  <%- include("partials/footer") %>