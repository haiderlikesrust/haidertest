<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title ? `${title} - ${siteName}` : siteName %>
  </title>
  <link rel="stylesheet" href="/styles.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" crossorigin="anonymous" />
  <script defer src="/theme.js"></script>
  <script defer src="/app.js"></script>
</head>

<body class="<%= user ? 'app-shell' : 'guest-shell' %>">
  <header class="topbar">
    <div class="topbar-left">
      <% if (user) { %>
        <button type="button" id="mobile-nav-toggle" class="mobile-nav-toggle">Menu</button>
        <% } %>
          <div class="logo"><a href="/">
              <%= siteName %>
            </a></div>
          <% if (user) { %>
            <span class="topbar-tagline">Private knowledge base</span>
            <% } %>
    </div>
    <% if (user) { %>
      <form class="search-form topbar-search" action="/search" method="GET">
        <input name="q" placeholder="Search <%= siteName %>" aria-label="Search wiki" />
      </form>
      <% } else { %>
        <div class="topbar-search-placeholder"></div>
        <% } %>
          <div class="top-right">
            <% if (user) { %>
              <span class="user-chip">
                <%= user.username %> (<%= user.role %>)
              </span>
              <form action="/logout" method="POST"><button type="submit">Log out</button></form>
              <% } %>
          </div>
  </header>
  <% if (user) { %>
    <div id="nav-backdrop" class="nav-backdrop"></div>
    <% } %>
      <div class="wiki-shell">
        <% if (user) { %>
          <aside class="sidebar">
            <h4>Navigation</h4>
            <nav class="side-nav">
              <a href="/">Main page</a>
              <a href="/search">Contents</a>
              <a href="/wiki/random">Random article</a>
            </nav>
            <% if (canEdit || user.role==="admin" ) { %>
              <h4>Workspace</h4>
              <nav class="side-nav">
                <% if (canEdit) { %><a href="/wiki/new">Create page</a>
                  <% } %>
                    <% if (user.role==="admin" ) { %><a href="/admin/users">Manage users</a>
                      <% } %>
              </nav>
              <% } %>
          </aside>
          <% } %>
            <main class="content">