<%- include("partials/header", { title: "Register" }) %>
<section class="login-shell">
  <div class="login-brand">
    <p class="auth-kicker">Invite Only</p>
    <h1>Join <%= siteName %></h1>
    <p>Create your account using an invite code generated by an admin.</p>
    <ul>
      <li>Invite code controls your role</li>
      <li>One-time use codes</li>
      <li>Code can expire if admin sets a date</li>
    </ul>
  </div>
  <div class="login-card">
    <h2>Create account</h2>
    <% if (error) { %><p class="error"><%= error %></p><% } %>
    <form method="POST" action="/register" class="stack auth-form">
      <label>Username <input type="text" name="username" required value="<%= formData.username %>" /></label>
      <label>Password <input type="password" name="password" required /></label>
      <label>Invite code <input type="text" name="inviteCode" required value="<%= formData.inviteCode %>" /></label>
      <button type="submit">Create account</button>
    </form>
    <p class="auth-footnote">Already have an account? <a href="/login">Log in</a>.</p>
  </div>
</section>
<%- include("partials/footer") %>
