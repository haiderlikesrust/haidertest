<%- include("partials/header", { title: "Search" }) %>
<h1>Search</h1>
<form action="/search" method="GET" class="search-form-inline">
  <input name="q" value="<%= queryText %>" placeholder="Search wiki" />
  <button type="submit">Search</button>
</form>

<% if (queryText) { %>
<h2>Results for "<%= queryText %>"</h2>
<ul class="search-results">
  <% results.forEach((result) => { %>
  <li>
    <a href="/wiki/<%= result.slug %>"><%= result.title %></a>
    <p><%- result.highlightedSnippet || result.snippet %>...</p>
  </li>
  <% }) %>
</ul>
<% } %>
<%- include("partials/footer") %>
